                              let tail = ''
                              let keys = get(g:, a:mode.'remap', {})
                              if len(keys) && type(keys) == type({})
                                while !empty(head)
                                  if has_key(keys, head)
                                    let head = keys[head]
                                    if empty(head)
                                      return
                                    endif
                                    break
                                  endif
                                  let tail = matchstr(head, '<[^<>]*>$\|.$') . tail
                                  let head = substitute(head, '<[^<>]*>$\|.$', '', '')
                                endwhile
                              endif
                              if empty(mapcheck(head.tail, a:mode))
                                exe a:mode.'map' flags head.tail a:rhs
                              endif
                            endfunction
                            
