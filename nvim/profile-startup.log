                                for l:snippet in l:source
                                  for l:prefix in l:snippet.prefix_alias
                                    let l:prefix_len = strchars(l:prefix)
                                    if strcharpart(l:before_text, l:before_text_len - l:prefix_len, l:prefix_len) !=# l:prefix
                                      continue
