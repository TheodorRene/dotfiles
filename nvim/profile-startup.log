    1              0.000003 if exists("did_indent_on")
                              finish
    1              0.000000 endif
    1              0.000001 let did_indent_on = 1
                            
    1              0.000001 augroup filetypeindent
    1              0.000002   au FileType * call s:LoadIndent()
    1              0.000001   func! s:LoadIndent()
                                if exists("b:undo_indent")
                                  exe b:undo_indent
                                  unlet! b:undo_indent b:did_indent
                                endif
                                let s = expand("<amatch>")
                                if s != ""
                                  if exists("b:did_indent")
                            	unlet b:did_indent
                                  endif
                            
                                  " When there is a dot it is used to separate filetype names.  Thus for
                                  " "aaa.bbb" load "indent/aaa.vim" and then "indent/bbb.vim".
                                  for name in split(s, '\.')
                                    " XXX: "[.]" in the pattern makes it a wildcard on Windows
                                    exe $'runtime! indent/{name}[.]{{vim,lua}}'
                                  endfor
                                endif
                              endfunc
    1              0.000001 augroup END

