                                end
                            
                                Xsetlist = function(...)
                                  return vim9.fn_ref(M, 'setloclist', vim.deepcopy({ 0 }), ...)
                                end
                            
                                cmd = ':Lfilter' .. bang
                              end
                            
                              firstchar = vim9.index(searchpat, 0)
                              lastchar = vim9.slice(searchpat, -1, nil)
