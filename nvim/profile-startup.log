                                local l = vim.split(line, "%s+")
                                local n = #l - 2
                            
                                if n == 0 then
                                  local commands = { builtin_list, extensions_list }
                                  -- TODO(clason): remove when dropping support for Nvim 0.9
                                  if vim.fn.has "nvim-0.11" == 1 then
                                    commands = vim.iter(commands):flatten():totable()
