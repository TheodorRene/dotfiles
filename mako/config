# mako — coral theme (matches waybar / wofi / swaylock / alacritty)

font=JetBrainsMono Nerd Font 10
background-color=#0d0d0dee
text-color=#d6d6d6
border-color=#e0645a
border-size=2
border-radius=8
padding=10
margin=8
width=360
height=120
default-timeout=5000
icons=1
max-icon-size=48
anchor=top-right
layer=overlay

# left-click invokes the notification's default action (e.g. focus Claude's terminal)
on-button-left=invoke-default-action
on-button-right=dismiss

[urgency=low]
border-color=#3a3a3a
text-color=#8a8a8a

[urgency=normal]
border-color=#e0645a

[urgency=high]
border-color=#ff5a4d
text-color=#ffffff
default-timeout=0
