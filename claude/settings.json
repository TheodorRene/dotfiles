{
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/scripts/claude-attention.sh waiting"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/scripts/claude-attention.sh idle"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/trc/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "impero-ai-skills@impero-plugins": true
  },
  "extraKnownMarketplaces": {
    "impero-plugins": {
      "source": {
        "source": "github",
        "repo": "impero-com/impero-ai-skills"
      }
    }
  },
  "effortLevel": "high",
  "theme": "dark"
}
